# Copie en .env (gitignored) pour le dev local. En prod, ces valeurs sont des
# VARIABLES DE REPO GitHub (publiques par nature : un ID analytics est exposé côté client).
# Ne RIEN versionner ici de réel — ce fichier n'est qu'un modèle.

# Provider : umami | posthog | ga  (laisser vide = aucun tracking)
VITE_ANALYTICS=

# --- Umami (self-host) ---
VITE_UMAMI_SRC=https://umami.is4.you/script.js
VITE_UMAMI_ID=

# --- Google Analytics ---
VITE_GA_ID=

# --- PostHog ---
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
